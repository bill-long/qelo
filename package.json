{
  "name": "qelo",
  "version": "0.1.0",
  "description": "A JMAP email client built with Tauri and SolidJS.",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "prepare": "lefthook install",
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "dev:server": "docker compose -f dev/stalwart/docker-compose.yml up -d",
    "dev:server:down": "docker compose -f dev/stalwart/docker-compose.yml down",
    "dev:seed": "node dev/stalwart/seed.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm lint:biome && pnpm lint:solid",
    "lint:biome": "biome check .",
    "lint:solid": "eslint .",
    "lint:fix": "biome check --write . && eslint . --fix",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "dompurify": "^3.4.9",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}

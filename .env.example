# Dev connection to the local Stalwart server (see dev/stalwart/README.md).
# Copy to `.env.local` (gitignored) and fill in the test account password.
#
# These drive the temporary Basic-auth dev login; they go away once OAuth (Phase 1)
# lands. Leaving the session URL unset uses the same-origin Vite dev proxy.

# VITE_JMAP_SESSION_URL="/.well-known/jmap"
VITE_JMAP_EMAIL="test@example.test"
VITE_JMAP_PASSWORD=""

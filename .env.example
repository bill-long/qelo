# Dev connection to the local Stalwart server (see dev/stalwart/README.md).
# Copy to `.env.local` (gitignored) and fill in the test account password.
#
# These drive the Basic-auth dev login used by the browser/PWA build, which has no Rust
# backend to run the OAuth flow (the desktop build authenticates via OAuth instead).
# Leaving the session URL unset uses the same-origin Vite dev proxy.

# VITE_JMAP_SESSION_URL="/.well-known/jmap"
VITE_JMAP_EMAIL="test@example.test"
VITE_JMAP_PASSWORD=""
